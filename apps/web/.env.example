BASE_URL=localhost
GOOGLE_ANALYTICS_ID=G-XXXXXXXXX
EXPORT_STATIC_FILES=false
VERCEL_OIDC_TOKEN=

# ── Database (Neon / Vercel Postgres) ─────────────────────────────────────────
# Pooled connection (app runtime)
DATABASE_URL=
# Direct connection (drizzle-kit migrations — bypasses pgBouncer)
DATABASE_URL_UNPOOLED=

# Parameters for constructing your own connection string
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# Parameters for Vercel Postgres Templates
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=

# ── Auth (next-auth) ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:4200
# bcrypt hash of admin password — never store plaintext
ADMIN_PASSWORD_HASH=